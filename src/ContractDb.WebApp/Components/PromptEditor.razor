@* Custom prompt text editor *@

<div class="form-group">
    <label>@Label</label>
    <textarea @bind="Text" rows="@Rows" placeholder="@Placeholder"></textarea>
</div>

@code {
    [Parameter] public string Label { get; set; } = "Custom Prompt:";
    [Parameter] public string Text { get; set; } = "";
    [Parameter] public EventCallback<string> TextChanged { get; set; }
    [Parameter] public int Rows { get; set; } = 3;
    [Parameter] public string Placeholder { get; set; } = "Enter your prompt...";
}
